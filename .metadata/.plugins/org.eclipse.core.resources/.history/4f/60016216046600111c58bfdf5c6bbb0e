	// 프로그램 전체에서 공유해서 사용할 연결(Connection) 객체
    private static Connection connection = null;

    // DB 접속 정보 변수
    private static final String URL = "jdbc:postgresql://localhost:5432/dvdrental";
    private static final String USER = "postgres";
    private static final String PASSWORD = "1234";

    // [분리 1] DB 연결을 담당하는 메서드
    public static void openConnection() {
        try {
            if (connection == null || connection.isClosed()) {
                System.out.println("🔄 PostgreSQL 데이터베이스 연결 시도 중...");
                connection = DriverManager.getConnection(URL, USER, PASSWORD);
                System.out.println("🎉 DB 연결 성공!");
            }
        } catch (SQLException e) {
            System.err.println("❌ DB 연결 중 에러 발생: " + e.getMessage());
            e.printStackTrace();
        }
    }

    // [분리 2] DB 닫기를 담당하는 메서드
    public static void closeConnection() {
        try {
            if (connection != null && !connection.isClosed()) {
                connection.close();
                System.out.println("🔒 DB 연결이 안전하게 닫혔습니다.");
            }
        } catch (SQLException e) {
            System.err.println("❌ DB 닫기 중 에러 발생: " + e.getMessage());
            e.printStackTrace();
        }
    }

    // 메인 실행 메서드
    public static void main(String[] args) {
        
        // 1. 필요할 때 연결을 엽니다.
        openConnection();
        
        // 2. 이곳에서 DB 작업(조회, 삽입 등)을 수행합니다.
        if (connection != null) {
            System.out.println(">> 여기서 SQL 쿼리를 실행하는 코드가 들어갑니다.");
        }
        
        // 3. 프로그램이 끝나기 직전, 혹은 작업이 완료되었을 때 연결을 완전히 닫습니다.
        closeConnection();
        
    }
}