	// 프로그램 전체에서 공유해서 사용할 연결(Connection) 객체
    private static Connection connection = null;

    // DB 접속 정보 변수
    private static final String URL = "jdbc:postgresql://localhost:5432/dvdrental";
    private static final String USER = "postgres";
    private static final String PASSWORD = "1234";

    // [분리 1] DB 연결을 담당하는 메서드
    public static void openConnection() {
        try {
            if (connection == null || connection.isClosed()) {
                System.out.println("🔄 PostgreSQL 데이터베이스 연결 시도 중...");
                connection = DriverManager.getConnection(URL, USER, PASSWORD);
                System.out.println("🎉 DB 연결 성공!");
            }
        } catch (SQLException e) {
            System.err.println("❌ DB 연결 중 에러 발생: " + e.getMessage());
            e.printStackTrace();
        }
    }

    // [분리 2] DB 닫기를 담당하는 메서드
    public static void closeConnection() {
        try {
            if (connection != null && !connection.isClosed()) {
                connection.close();
                System.out.println("🔒 DB 연결이 안전하게 닫혔습니다.");
            }
        } catch (SQLException e) {
            System.err.println("❌ DB 닫기 중 에러 발생: " + e.getMessage());
            e.printStackTrace();
        }
    }

    // 메인 실행 메서드
    public static void main(String[] args) {
        
        // 1. 필요할 때 연결을 엽니다.
        openConnection();
        
        // 2. 이곳에서 DB 작업(조회, 삽입 등)을 수행합니다.
        if (connection != null) {
        		String sql = "select * from employees";
            
            // 배달원(PreparedStatement)과 바구니(ResultSet)를 선언합니다.
            PreparedStatement pstmt = null;
            ResultSet rs = null;
            
            try {
                // 자바가 DB에게 던질 쿼리를 배달원에게 장전합니다.
                pstmt = connection.prepareStatement(sql);
                
                System.out.println("🔎 SQL 쿼리를 실행합니다: " + sql);
                // 쿼리를 실행하고 결과를 바구니(rs)에 담아옵니다.
                rs = pstmt.executeQuery();
                
                System.out.println("--- [조회 결과 시작] ---");
                
                // rs.next()는 바구니에 다음 줄 데이터가 있으면 true를 반환하고, 그 줄로 이동합니다.
                while (rs.next()) {
                    // 'datname' 컬럼에 있는 텍스트 데이터를 꺼내옵니다.
                    String dbName = rs.getString("datname");
                    System.out.println("📁 데이터베이스 이름: " + dbName);
                }
                
                System.out.println("--- [조회 결과 끝] ---");
                
            } catch (SQLException e) {
                System.err.println("❌ SQL 실행 중 오류가 발생했습니다.");
                e.printStackTrace();
            } finally {
                // ⚠️ 다 쓴 배달원과 바구니는 꼭 역순으로 닫아주어야 메모리 누수가 안 생깁니다!
                try { if (rs != null) rs.close(); } catch (Exception e) {}
                try { if (pstmt != null) pstmt.close(); } catch (Exception e) {}
            }
        }
        
        // 3. 프로그램이 끝나기 직전, 혹은 작업이 완료되었을 때 연결을 완전히 닫습니다.
        closeConnection();
        
    }
}