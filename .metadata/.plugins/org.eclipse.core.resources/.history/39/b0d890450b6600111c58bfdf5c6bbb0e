package Proj_0612_javadb;

import java.sql.Connection;
import java.sql.PreparedStatement;
import java.sql.ResultSet;
import java.sql.SQLException;

public class DepartmentDAO {

    // 외부(Main)로부터 Connection을 넘겨받아 조회를 수행하는 메서드
    public void printAllDepartments(Connection connection) {
        if (connection == null) {
            System.out.println("❌ 연결된 데이터베이스가 없습니다.");
            return;
        }

        String sql = "SELECT * FROM departments";
        PreparedStatement pstmt = null;
        ResultSet rs = null;

        try {
            pstmt = connection.prepareStatement(sql);
            System.out.println("🔎 SQL 쿼리를 실행합니다: " + sql);
            rs = pstmt.executeQuery();

            System.out.println("--- [부서 목록 조회 결과] ---");
            
            while (rs.next()) {
                // 원본 코드의 컬럼명 규격(id, name) 유지
                int deptId = rs.getInt("id");
                String deptName = rs.getString("name");

                System.out.println("🏢 부서번호: " + deptId + " | 🏷️ 부서명: " + deptName);
            }
            
            System.out.println("---------------------------");

        } catch (SQLException e) {
            System.err.println("❌ SQL 실행 중 오류가 발생했습니다.");
            e.printStackTrace();
        } finally {
            // 원본 코드의 자원 반납 로직 (역순 close)
            try { if (rs != null) rs.close(); } catch (Exception e) {}
            try { if (pstmt != null) pstmt.close(); } catch (Exception e) {}
        }
    }
}