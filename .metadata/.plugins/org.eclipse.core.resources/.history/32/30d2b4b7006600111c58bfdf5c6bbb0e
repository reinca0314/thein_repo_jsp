package Proj_0612_javadb;

import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.SQLException;

public class MyMain {

    // ⚠️ 본인의 PostgreSQL 설정에 맞게 수정해야 하는 3가지 정보
    private static final String URL = "jdbc:postgresql://localhost:5432/postgres";
    private static final String USER = "postgres"; // 기본 관리자 계정 아이디
    private static final String PASSWORD = "1234";

    public static void main(String[] args) {
        System.out.println("PostgreSQL 연결 시도 중...");

        // try-with-resources 구문: 연결이 끝나면 자동으로 접속을 닫아줍니다.
        try (Connection connection = DriverManager.getConnection(URL, USER, PASSWORD)) {
            
            if (connection != null) {
                System.out.println("🎉 PostgreSQL 데이터베이스에 성공적으로 연결되었습니다!");
            } else {
                System.out.println("❌ 연결에 실패했습니다.");
            }

        } catch (SQLException e) {
            System.err.println("❌ 데이터베이스 접속 중 에러가 발생했습니다.");
            System.err.println("사유: " + e.getMessage());
            e.printStackTrace();
        }
    }
}